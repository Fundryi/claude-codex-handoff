{
  "name": "codex-live-viewer",
  "version": "1.3.0",
  "private": true,
  "description": "Lightweight tray and browser dashboard for all local Codex CLI sessions, including headless handoffs.",
  "main": "codex-live-viewer.js",
  "scripts": {
    "start": "node codex-live-viewer.js serve",
    "stop": "node codex-live-viewer.js stop",
    "test": "node --test tests/*.test.js",
    "tray": "cargo run --manifest-path tray-launcher/Cargo.toml",
    "build:tray": "cargo build --release --locked --manifest-path tray-launcher/Cargo.toml"
  },
  "bin": {
    "codex-live-viewer": "codex-live-viewer.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "codex-live-viewer.js",
    "viewer-ui.html",
    "assets/logo.svg",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fundryi/codex-live-viewer.git"
  },
  "homepage": "https://github.com/Fundryi/codex-live-viewer#readme",
  "bugs": "https://github.com/Fundryi/codex-live-viewer/issues",
  "license": "MIT"
}
