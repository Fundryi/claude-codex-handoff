{
  "name": "claude-codex-handoff",
  "version": "2.6.0",
  "private": true,
  "description": "Claude Code -> Codex handoffs that don't get stuck: bundled codex plugin fork + live web dashboard to start, watch, resume and cancel headless Codex runs.",
  "main": "codex-live-viewer.js",
  "scripts": {
    "start": "node codex-live-viewer.js serve",
    "stop": "node codex-live-viewer.js stop",
    "test": "node --test tests/*.test.js",
    "sync:viewer": "node -e \"const fs=require('fs');fs.mkdirSync('plugin/viewer/assets',{recursive:true});for(const f of['codex-live-viewer.js','viewer-ui.html','assets/logo.svg'])fs.copyFileSync(f,'plugin/viewer/'+f)\"",
    "tray": "cargo run --manifest-path tray-launcher/Cargo.toml",
    "build:tray": "cargo build --release --locked --manifest-path tray-launcher/Cargo.toml"
  },
  "bin": {
    "codex-live-viewer": "codex-live-viewer.js"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "codex-live-viewer.js",
    "viewer-ui.html",
    "assets/logo.svg",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fundryi/claude-codex-handoff.git"
  },
  "homepage": "https://github.com/Fundryi/claude-codex-handoff#readme",
  "bugs": "https://github.com/Fundryi/claude-codex-handoff/issues",
  "license": "UNLICENSED"
}
